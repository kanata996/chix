package reqx

import "errors"

var (
	// ErrNilResponseWriter 表示调用方传入了 nil http.ResponseWriter。
	ErrNilResponseWriter = errors.New("reqx: response writer must not be nil")
	// ErrNilRequest 表示调用方传入了 nil *http.Request。
	ErrNilRequest = errors.New("reqx: request must not be nil")
	// ErrNilTarget 表示调用方传入了 nil target。
	ErrNilTarget = errors.New("reqx: target must not be nil")
	// ErrInvalidDecodeTarget 表示 JSON 解码 target 不是非 nil 指针。
	ErrInvalidDecodeTarget = errors.New("reqx: invalid decode target")
	// ErrInvalidValidateTarget 表示 Validate* target 不是非 nil `*struct`。
	ErrInvalidValidateTarget = errors.New("reqx: invalid validate target")
)
